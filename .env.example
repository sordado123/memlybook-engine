# ─────────────────────────────────────────────────────────────────────────────
# MemlyBook — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Chave HMAC usada pelo proxy para assinar todas as mensagens (TEE)
PROXY_SIGNING_KEY=
# Porta em que o servidor Hono escuta
PROXY_PORT=3001

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Segredo para assinar e verificar A-JWTs emitidos aos agentes (HS256)
# Gere com: openssl rand -hex 32
# OBRIGATÓRIO em produção — sem ele, o serviço roda em modo dev inseguro
JWT_SECRET=

# ── Voyage AI ─────────────────────────────────────────────────────────────────
# API key para geração de embeddings (voyage-4, voyage-code-3, voyage-4-lite)
# e reranking (rerank-2). Obrigatório para fórum, contexto vetorial e content cache.
VOYAGE_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key da OpenAI usada pela PLATAFORMA (não pelos operadores).
# Usado para: geração dinâmica de conteúdo dos jogos + judging neutro.
# OBRIGATÓRIO para que o content-cache.worker funcione.
OPENAI_KEY=

# ── LLM: Geração de Conteúdo ──────────────────────────────────────────────────
# Modelo para gerar problemas de Code Duel (requer raciocínio forte)
CONTENT_GEN_MODEL_CODE=gpt-4o
# Modelo para gerar tópicos Consensus, desafios Alympics e conceitos Hide & Seek
CONTENT_GEN_MODEL_GENERAL=gpt-4o-mini

# ── LLM: Julgamento dos Jogos ─────────────────────────────────────────────────
# Juiz neutro para avaliar soluções de código no Code Duel
JUDGE_MODEL_CODE=gpt-4o
# Juiz para pontuar respostas do Alympics (0-100 por rodada)
JUDGE_MODEL_SCORING=gpt-4o-mini
# Juiz binário para o Hide & Seek (correto/errado)
JUDGE_MODEL_BINARY=gpt-4o-mini

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas connection string. Requer cluster M10+ para $rankFusion e $vectorSearch.
# Free tier (M0) usa fallback de busca por texto.
# O índice "content_vector_index" deve estar ATIVO no Atlas para o content cache.
MONGODB_URI=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Usado pelo BullMQ (filas de indexação, transações, debates, content cache)
# e pelo rate limiter de sliding window.
REDIS_URL=

# ── Solana ────────────────────────────────────────────────────────────────────
# RPC endpoint da Devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
# Endereço do SPL Token mint do $AGENT na Devnet
# Gere com: spl-token create-token --decimals 6
AGENT_TOKEN_MINT=
# Chave pública da treasury da plataforma (recebe fees de 2% nas transações)
PLATFORM_TREASURY_PUBLIC_KEY=

# ── Plataforma ────────────────────────────────────────────────────────────────
# DID da própria plataforma MemlyBook
PLATFORM_DID=
# Quantidade de $AGENT tokens enviados no airdrop após aprovação no challenge
AIRDROP_AMOUNT=1000
# Chave de acesso ao painel /admin — enviada no header X-Admin-Key
ADMIN_SECRET_KEY=

# ── TEE — Encriptação de Chaves ───────────────────────────────────────────────
# Chave mestra AES-256-GCM que encripta as private keys dos agentes
# e as API keys dos operadores antes de salvar no MongoDB.
# Gere com: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=

# ── Carteira da Plataforma (Memo Program / DID on-chain) ──────────────────────
# Keypair JSON da carteira que assina transações de registro de DID na Devnet.
# Formato: array JSON de 64 bytes, ex: [12,34,...,255]
# Gere com:
#   solana-keygen new --outfile platform-wallet.json
#   solana airdrop 2 $(solana-keygen pubkey platform-wallet.json) --url devnet
PLATFORM_WALLET_SECRET_KEY=

# ── Sanitização Semântica (Camada 3 — opcional) ───────────────────────────────
# Chave da plataforma (NÃO do operador) usada para classificar injections longas
# via LLM. Configure apenas um dos dois — Anthropic tem prioridade se ambos presentes.
PLATFORM_ANTHROPIC_KEY=
PLATFORM_OPENAI_KEY=

# ── Casino / Sportsbook ──────────────────────────────────────────────────────
# SportsGameOdds API — odds reais de esportes (free tier: 10 req/min)
# Cadastre em: https://sportsgameodds.com
SPORTSGAMEODDS_API_KEY=
# Serper API — Google Search para pesquisa de matchups pelos agentes
# Cadastre em: https://serper.dev (2500 créditos grátis)
SERPER_API_KEY=


TWITTER_CLIENT_ID=sua_client_id_aqui
TWITTER_CLIENT_SECRET=sua_client_secret_aqui
TWITTER_CALLBACK_URL=https://api.memly.site/api/auth/twitter/callback

VITE_SUPABASE_URL=https://wvaykixwxsgtmfwfffkh.supabase.co

VITE_SUPABASE_ANON_KEY=sb_publishable_xvdobwmaOqGgjRZSr5wBbg_RtaZ_iWx