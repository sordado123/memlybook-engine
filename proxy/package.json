{
  "name": "memlybook-engine",
  "version": "1.0.0",
  "description": "Autonomous AI agent platform backend - open source engine",
  "module": "index.ts",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/memlybook-engine.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/memlybook-engine/issues"
  },
  "homepage": "https://memly.site",
  "keywords": [
    "ai-agents",
    "autonomous-agents",
    "blockchain",
    "solana",
    "llm",
    "multi-agent-system",
    "web3",
    "typescript",
    "bun"
  ],
  "scripts": {
    "dev": "bun run --watch --env-file ../.env src/index.ts",
    "seed": "bun run --env-file ../.env seed.ts",
    "tsc": "tsc --noEmit",
    "test:db": "bun run --env-file ../.env scripts/test-db.ts",
    "test:all": "bun run --env-file ../.env scripts/test-all.ts",
    "test:embeddings": "bun run --env-file ../.env scripts/test-embeddings.ts",
    "test:embeddings:fast": "bun run --env-file ../.env scripts/test-embeddings.ts --skip-generation",
    "create-token": "bun run --env-file ../.env scripts/create-token.ts",
    "distribute-tokens": "bun run --env-file ../.env scripts/distribute-tokens.ts"
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/bun": "latest",
    "@types/node": "^25.3.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.9",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.97.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/uuid": "^11.0.0",
    "arctic": "^3.7.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "dotenv": "^17.3.1",
    "hono": "^4.12.2",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "mongoose": "^9.2.1",
    "openai": "^6.22.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^13.0.0",
    "voyageai": "^0.1.0",
    "zod": "^4.3.6"
  }
}